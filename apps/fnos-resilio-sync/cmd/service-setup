#!/bin/bash
# =============================================================
# service-setup — Resilio Sync 服务配置
# =============================================================

LOG_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.log"
PID_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.pid"

APP_DIR="${TRIM_APPDEST}"
APP_DATA_DIR="${TRIM_PKGVAR}"

SERVICE_COMMAND="$APP_DIR/bin/${TRIM_APPNAME}-server $APP_DATA_DIR"
SVC_BACKGROUND=y
SVC_WRITE_PID=y

# ---- 启动前：清理可能残留的孤儿进程 ----
service_prestart() {
    pkill -x "rslsync" 2>/dev/null || true
    sleep 1
}

# ---- 安装后：初始化数据目录和配置文件 ----
service_postinst() {
    mkdir -p "$APP_DATA_DIR/storage" 2>/dev/null || true

    # 生成默认 sync.conf（仅在不存在时创建，避免覆盖用户修改）
    if [ ! -f "$APP_DATA_DIR/sync.conf" ]; then
        cat > "$APP_DATA_DIR/sync.conf" << CONF
{
    "storage_path": "${APP_DATA_DIR}/storage",
    "pid_file": "${APP_DATA_DIR}/rslsync.pid",
    "display_new_version": false,
    "use_upnp": true,
    "directory_root": "/",
    "directory_root_policy": "belowroot",
    "webui": {
        "listen": "0.0.0.0:8890",
        "allow_empty_password": false,
        "context": "{\"folder_blacklist\": [\"/lost\\\\+found\", \"/bin\", \"/boot\", \"/dev\", \"/etc\", \"/lib\", \"/lib32\", \"/lib64\", \"/media\", \"/mnt\", \"/opt\", \"/proc\", \"/root\", \"/run\", \"/sbin\", \"/srv\", \"/sys\", \"/tmp\", \"/usr\", \"/var\"]}"
    }
}
CONF
    fi

    # 写入 Pro 许可证文件
    if [ ! -f "$APP_DATA_DIR/ResilioSyncPro.btskey" ]; then
        cat > "$APP_DATA_DIR/ResilioSyncPro.btskey" << 'KEY'
btos1_
KEY
    fi
}

# ---- 卸载前：确保进程被终止 ----
service_preuninst() {
    pkill -x "rslsync" 2>/dev/null || true
    sleep 1
    pkill -9 -x "rslsync" 2>/dev/null || true
}

service_poststop() {
    service_preuninst
}
