#!/bin/bash
# =============================================================
# main — fnOS 服务启停入口（自包含，无外部依赖）
# 用法: main start|stop|status|log
# =============================================================

APP_NAME="gocron"
APP_DIR="${TRIM_APPDEST}"
DATA_DIR="${TRIM_PKGVAR}"
LOG_FILE="${TRIM_PKGVAR}/${APP_NAME}.log"
PID_FILE="${TRIM_PKGVAR}/${APP_NAME}.pid"

# ---- 启动 ----
do_start() {
    date > "$LOG_FILE"

    # 启动 gocron-server
    cd "$DATA_DIR" || exit 1
    export HOME="$DATA_DIR"
    "$APP_DIR/bin/gocron-server" "$DATA_DIR" >> "$LOG_FILE" 2>&1 &
    PID1=$!
    echo "$PID1" > "$PID_FILE"
    echo "[$(date)] Started gocron-server (PID: $PID1)" >> "$LOG_FILE"

    # 启动 gocron-node
    "$APP_DIR/bin/gocron-node" "$DATA_DIR" >> "$LOG_FILE" 2>&1 &
    PID2=$!
    echo "$PID2" >> "$PID_FILE"
    echo "[$(date)] Started gocron-node (PID: $PID2)" >> "$LOG_FILE"
}

# ---- 停止 ----
do_stop() {
    if [ -f "$PID_FILE" ]; then
        while read -r pid; do
            [ -z "$pid" ] && continue
            if kill -0 "$pid" 2>/dev/null; then
                echo "[$(date)] Stopping PID $pid ($(ps -p "$pid" -o comm= 2>/dev/null))" >> "$LOG_FILE"
                kill -TERM "$pid" 2>/dev/null
            fi
        done < "$PID_FILE"

        # 等待进程退出
        local i=0
        while [ $i -lt 15 ]; do
            local alive=0
            while read -r pid; do
                [ -z "$pid" ] && continue
                kill -0 "$pid" 2>/dev/null && alive=1
            done < "$PID_FILE"
            [ "$alive" -eq 0 ] && break
            sleep 1
            i=$((i + 1))
        done

        # 强制杀掉残留
        while read -r pid; do
            [ -z "$pid" ] && continue
            kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null
        done < "$PID_FILE"

        rm -f "$PID_FILE"
    fi

    # 按进程名清理
    pkill -x "gocron" 2>/dev/null || true
    pkill -x "gocron-node" 2>/dev/null || true
}

# ---- 状态 ----
do_status() {
    if [ -f "$PID_FILE" ]; then
        while read -r pid; do
            [ -z "$pid" ] && continue
            if ! kill -0 "$pid" 2>/dev/null; then
                rm -f "$PID_FILE"
                exit 1
            fi
        done < "$PID_FILE"
        exit 0
    fi
    exit 1
}

# ---- 日志 ----
do_log() {
    if [ -f "$LOG_FILE" ]; then
        cat "$LOG_FILE"
    fi
}

# ---- 调度 ----
case "$1" in
    start)  do_start  ;;
    stop)   do_stop   ;;
    status) do_status ;;
    log)    do_log    ;;
    *)
        echo "Usage: $0 {start|stop|status|log}"
        exit 1
        ;;
esac
