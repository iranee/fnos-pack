#!/bin/bash
echo "[$(date)] upgrade_init" >> "/var/log/apps/${TRIM_APPNAME}.log"

PID_FILE="${TRIM_PKGVAR}/${TRIM_APPNAME}.pid"
if [ -f "$PID_FILE" ]; then
    while read -r pid; do
        [ -z "$pid" ] && continue
        kill -TERM "$pid" 2>/dev/null
    done < "$PID_FILE"
    sleep 2
    while read -r pid; do
        [ -z "$pid" ] && continue
        kill -0 "$pid" 2>/dev/null && kill -9 "$pid" 2>/dev/null
    done < "$PID_FILE"
    rm -f "$PID_FILE"
fi

pkill -x "gocron" 2>/dev/null || true
pkill -x "gocron-node" 2>/dev/null || true

exit 0
